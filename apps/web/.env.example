# Voxic environment — copy to .env and fill in your paths.
# Nuxt maps these to runtimeConfig via the NUXT_ prefix (required).
# All values are required for the app to find its data sources.

# Root directory where MaiMemo writes daily articles + word JSON
# (e.g. .../2026/07/05-article.md). Articles are still read from here.
NUXT_MAIMEMO_NAS_ROOT=/path/to/maimemo/data

# GPT-SoVITS API base (runs locally).
NUXT_GPTSOVITS_BASE=http://127.0.0.1:9880

# Voice catalog files (rotation + the trained voice_list).
NUXT_VOICE_ROTATION_PATH=/path/to/voice_rotation.json
NUXT_VOICE_LIST_PATH=/path/to/voice_list_local.txt

# Eudic API token. If NUXT_EUDIC_TOKEN is empty, the server reads EUDIC_TOKEN
# from the file at NUXT_EUDIC_SECRETS_PATH (one `EUDIC_TOKEN=...` line).
NUXT_EUDIC_TOKEN=
NUXT_EUDIC_SECRETS_PATH=/path/to/secrets-file

# Local SQLite database + TTS audio cache (relative to apps/web).
NUXT_DB_PATH=./data/app.db
NUXT_TTS_CACHE_DIR=./data/tts

# Postgres — primary source for MaiMemo word data (forget/vague/familiar + progress).
# The MaiMemo cron writes to maimemo.daily_snapshots + maimemo.daily_items.
# Password: set NUXT_PG_PASSWORD here, OR leave blank to read ~/.pgpass.
NUXT_PG_HOST=
NUXT_PG_PORT=5432
NUXT_PG_DBNAME=
NUXT_PG_USER=
NUXT_PG_PASSWORD=
NUXT_PG_PASS_FILE=~/.pgpass
