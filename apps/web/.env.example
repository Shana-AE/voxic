# Voxic environment — copy to .env and fill in your paths.
# All values are required for the app to find its data sources.

# Root directory where MaiMemo writes daily articles + word JSON
# (e.g. .../2026/07/05-article.md, .../05.json).
MAIMEMO_NAS_ROOT=/path/to/maimemo/data

# GPT-SoVITS API base (runs locally).
GPTSOVITS_BASE=http://127.0.0.1:9880

# Voice catalog files (rotation + the trained voice_list).
VOICE_ROTATION_PATH=/path/to/voice_rotation.json
VOICE_LIST_PATH=/path/to/voice_list_local.txt

# Eudic API token. If empty, the server also reads EUDIC_TOKEN from the file at
# EUDIC_SECRETS_PATH (one `EUDIC_TOKEN=...` line).
EUDIC_TOKEN=
EUDIC_SECRETS_PATH=/path/to/secrets-file

# Local SQLite database + TTS audio cache (relative to apps/web).
DB_PATH=./data/app.db
TTS_CACHE_DIR=./data/tts
